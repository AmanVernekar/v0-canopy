# Canopy environment variables.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.

# Required — Vercel AI Gateway. Used to call claude-sonnet-4.5 from the
# /api/agent route. Get from https://vercel.com/dashboard → AI → Gateway.
AI_GATEWAY_API_KEY=

# Required — Bright Data MCP. Used by the agent to scrape live UK funding pages.
# Get from https://brightdata.com/cp/api_keys (or skip; agent will fall back
# to /data/funds-fallback.json and disclose that in the dossier).
BRIGHT_DATA_TOKEN=

# Optional but polite — OpenAlex requires a contact email for higher rate
# limits. Used by the search_evidence tool. Just put your real email here.
OPENALEX_EMAIL=
