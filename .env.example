# Canopy environment variables.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.

# Required — Anthropic API key. Used to call claude-sonnet-4.5 from the
# /api/agent route. Get from https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=

# Required — Bright Data API token. Used by the agent's scrape_funding_page
# tool (Bright Data Web Unlocker REST API) to verify live status of UK
# funding schemes. Get from https://brightdata.com/cp/api_keys (or skip;
# agent will fall back to /data/funds-fallback.json and disclose that).
BRIGHT_DATA_TOKEN=

# Optional — Bright Data Web Unlocker zone name. Defaults to "web_unlocker1"
# (the default zone new accounts get). Override only if you renamed the zone
# in the Bright Data dashboard.
BRIGHT_DATA_ZONE=

# Optional but polite — OpenAlex requires a contact email for higher rate
# limits. Used by the search_evidence tool. Just put your real email here.
OPENALEX_EMAIL=
